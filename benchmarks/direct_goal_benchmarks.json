[
  {
    "name": "prop_imp_self",
    "category": "prop_logic",
    "difficulty": "easy",
    "goal": "P \\<longrightarrow> P",
    "expected_method": "simp/auto"
  },
  {
    "name": "prop_and_comm",
    "category": "prop_logic",
    "difficulty": "easy",
    "goal": "P \\<and> Q \\<longleftrightarrow> Q \\<and> P",
    "expected_method": "blast"
  },
  {
    "name": "prop_or_comm",
    "category": "prop_logic",
    "difficulty": "easy",
    "goal": "P \\<or> Q \\<longleftrightarrow> Q \\<or> P",
    "expected_method": "blast"
  },
  {
    "name": "prop_imp_trans",
    "category": "prop_logic",
    "difficulty": "easy",
    "goal": "(P \\<longrightarrow> Q) \\<longrightarrow> (Q \\<longrightarrow> R) \\<longrightarrow> P \\<longrightarrow> R",
    "expected_method": "blast"
  },
  {
    "name": "prop_de_morgan_and",
    "category": "prop_logic",
    "difficulty": "easy",
    "goal": "\\<not> (P \\<and> Q) \\<longleftrightarrow> \\<not> P \\<or> \\<not> Q",
    "expected_method": "blast"
  },
  {
