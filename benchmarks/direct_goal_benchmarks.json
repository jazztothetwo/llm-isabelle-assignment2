  },
  {
    "name": "list_length_map",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "length (map f xs) = length xs",
    "expected_method": "simp"
  },
  {
    "name": "list_map_map",
    "category": "list_basic",
    "difficulty": "medium",
    "goal": "map f (map g xs) = map (f \\<circ> g) xs",
    "expected_method": "simp"
  },
  {
    "name": "list_foldr_append",
    "category": "list_fold",
    "difficulty": "medium",
    "goal": "foldr f (xs @ ys) z = foldr f xs (foldr f ys z)",
