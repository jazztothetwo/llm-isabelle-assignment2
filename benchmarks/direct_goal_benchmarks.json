  },
  {
    "name": "list_nth_map",
    "category": "list_medium",
    "difficulty": "hard",
    "goal": "i < length xs \\<Longrightarrow> map f xs ! i = f (xs ! i)",
    "expected_method": "induction xs arbitrary: i; cases i; simp"
  },
  {
