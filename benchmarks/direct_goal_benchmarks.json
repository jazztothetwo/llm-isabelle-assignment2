  },
  {
    "name": "list_filter_append",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "filter P (xs @ ys) = filter P xs @ filter P ys",
    "expected_method": "simp"
  },
  {
    "name": "list_take_length_append",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "take (length xs) (xs @ ys) = xs",
    "expected_method": "simp"
  },
  {
    "name": "list_drop_length_append",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "drop (length xs) (xs @ ys) = ys",
    "expected_method": "simp"
  },
  {
    "name": "list_set_append",
    "category": "list_set",
    "difficulty": "easy",
    "goal": "set (xs @ ys) = set xs \\<union> set ys",
