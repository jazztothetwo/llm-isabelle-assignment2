  },
  {
    "name": "list_append_assoc",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "(xs @ ys) @ zs = xs @ (ys @ zs)",
    "expected_method": "simp"
  },
  {
    "name": "list_rev_rev",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "rev (rev xs) = xs",
    "expected_method": "simp"
  },
  {
    "name": "list_length_append",
    "category": "list_basic",
    "difficulty": "easy",
    "goal": "length (xs @ ys) = length xs + length ys",
